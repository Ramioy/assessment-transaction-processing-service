{
  "name": "assessment-transaction-processing-service",
  "version": "1.0.0",
  "description": "Payment transaction processing microservice",
  "author": {
    "name": "YOIMAR MORENO BERTEL",
    "email": "Yoimar.mb@outlook.com",
    "url": "[Linkedin] https://www.linkedin.com/in/yoimar-mb/"
  },
  "private": false,
  "license": "GPL-3.0-only",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/unit/jest.config.mjs",
    "test:watch": "jest --config ./test/unit/jest.config.mjs --watch",
    "test:cov": "jest --config ./test/unit/jest.config.mjs --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/e2e/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/cors": "~9.0.0",
    "@fastify/helmet": "~11.0.0",
    "@fastify/static": "~7.0.0",
    "@nestjs/common": "~10.0.0",
    "@nestjs/config": "~3.0.0",
    "@nestjs/core": "~10.0.0",
    "@nestjs/platform-fastify": "~10.0.0",
    "@nestjs/swagger": "~7.4.2",
    "joi": "~17.11.0",
    "reflect-metadata": "~0.1.12",
    "rxjs": "~7.8.1",
    "zod": "~4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "~9.0.0",
    "@nestjs/cli": "~10.0.0",
    "@nestjs/schematics": "~10.0.0",
    "@nestjs/testing": "~10.0.0",
    "@swc/cli": "~0.1.65",
    "@swc/core": "~1.15.18",
    "@swc/jest": "~0.2.39",
    "@types/jest": "~29.5.0",
    "@types/node": "~20.3.1",
    "@types/supertest": "~6.0.0",
    "eslint": "~9.0.0",
    "eslint-config-prettier": "~9.0.0",
    "eslint-plugin-prettier": "~5.0.0",
    "globals": "~15.0.0",
    "jest": "~29.5.0",
    "prettier": "~3.0.0",
    "source-map-support": "~0.5.21",
    "supertest": "~6.3.0",
    "ts-loader": "~9.4.3",
    "ts-node": "~10.9.1",
    "tsconfig-paths": "~4.2.0",
    "typescript": "~5.1.3",
    "typescript-eslint": "~8.0.0"
  }
}
