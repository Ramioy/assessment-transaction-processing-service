# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Configuration
.env* text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
.editorconfig text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.zip binary
*.tar binary
*.gz binary

# Archives
*.7z binary
*.rar binary

# Diff and merge settings
*.package.json merge=union
package-lock.json merge=union
yarn.lock merge=union
pnpm-lock.yaml merge=union

# Don't export these files
.git export-ignore
.gitignore export-ignore
.gitattributes export-ignore
.github export-ignore
.editorconfig export-ignore
.env.example export-ignore
Dockerfile export-ignore
docker-compose.yml export-ignore
.dockerignore export-ignore
test export-ignore
doc export-ignore
script export-ignore
