NODE_ENV=production

PORT=3002
HOST=0.0.0.0

LOG_LEVEL=info

CORS_ENABLED=true
CORS_ORIGIN=https://your-frontend-domain.com

API_PREFIX=/api
API_VERSION=v1

API_KEY_ENABLED=true
API_KEY=your-production-secret-key-change-me

ENABLE_SWAGGER=false
ENABLE_HEALTH_CHECK=true

APP_NAME=transaction-processing-service
APP_DESCRIPTION=Payment transaction processing microservice

# DB Domain Service (persistence delegated via HTTP — see ADR-001)
DB_DOMAIN_SERVICE_URL=http://db-domain-service:3000
DB_DOMAIN_SERVICE_API_KEY=your-production-api-key-here

# Payment Provider Configuration
PAYMENT_PROVIDER_ENVIRONMENT=production
PAYMENT_PROVIDER_SANDBOX_URL=https://sandbox.wompi.co/v1
PAYMENT_PROVIDER_PRODUCTION_URL=https://production.wompi.co/v1
PAYMENT_PROVIDER_PUBLIC_KEY=pub_prod_your_public_key_here
PAYMENT_PROVIDER_PRIVATE_KEY=prv_prod_your_private_key_here
PAYMENT_PROVIDER_EVENTS_KEY=prod_events_your_events_key_here
PAYMENT_PROVIDER_INTEGRITY_KEY=prod_integrity_your_integrity_key_here
