NODE_ENV=development

PORT=3002
HOST=0.0.0.0

LOG_LEVEL=debug

CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

API_PREFIX=/api
API_VERSION=v1

API_KEY_ENABLED=false
API_KEY=your-development-secret-key-change-in-production

ENABLE_SWAGGER=true
ENABLE_HEALTH_CHECK=true

APP_NAME=transaction-processing-service
APP_DESCRIPTION=Payment transaction processing microservice

# DB Domain Service (persistence delegated via HTTP — see ADR-001)
DB_DOMAIN_SERVICE_URL=http://localhost:3000
DB_DOMAIN_SERVICE_API_KEY=your-development-secret-key-change-in-production

# Payment Provider Configuration
PAYMENT_PROVIDER_ENVIRONMENT=sandbox
PAYMENT_PROVIDER_SANDBOX_URL=https://sandbox.wompi.co/v1
PAYMENT_PROVIDER_PRODUCTION_URL=https://production.wompi.co/v1
PAYMENT_PROVIDER_PUBLIC_KEY=pub_stagtest_your_public_key_here
PAYMENT_PROVIDER_PRIVATE_KEY=prv_stagtest_your_private_key_here
PAYMENT_PROVIDER_EVENTS_KEY=stagtest_events_your_events_key_here
PAYMENT_PROVIDER_INTEGRITY_KEY=stagtest_integrity_your_integrity_key_here
